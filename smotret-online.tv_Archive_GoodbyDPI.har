            "text": "{\n    \"CineMan Фитнес\": {\n        \"displayName\": \"CineMan Фитнес\",\n        \"programmes\": [\n            {\n                \"start\": \"20251008062200 +0300\",\n                \"stop\": \"20251008072200 +0300\",\n                \"title\": \"Степ Жиросжигающий функционал\"\n            },\n            {\n                \"start\": \"20251008072200 +0300\",\n                \"stop\": \"20251008074000 +0300\",\n                \"title\": \"МФР Пилатес с Foam Roller, для новичков\"\n            },\n            {\n                \"start\": \"20251008074000 +0300\",\n                \"stop\": \"20251008083600 +0300\",\n                \"title\": \"Йога Вечерняя йога с Шавасаной\"\n            },\n            {\n                \"start\": \"20251008083600 +0300\",\n                \"stop\": \"20251008090000 +0300\",\n                \"title\": \"Йога Вечерняя йога Чандра Намаскар\"\n            },\n            {\n                \"start\": \"20251008090000 +0300\",\n                \"stop\": \"20251008094500 +0300\",\n                \"title\": \"Фитнес Танцевальная тренировка дома, сжигаем калории 45 минут в танцах\"\n            },\n            {\n                \"start\": \"20251008094500 +0300\",\n                \"stop\": \"20251008100700 +0300\",\n                \"title\": \"Фитнес Танцевальная тренировка дома, танцы для похудения дома\"\n            },\n            {\n                \"start\": \"20251008100700 +0300\",\n                \"stop\": \"20251008101500 +0300\",\n                \"title\": \"Фитнес Танцевальная тренировка на все тело, танцы для похудения дома\"\n            },\n            {\n                \"start\": \"20251008101500 +0300\",\n                \"stop\": \"20251008102500 +0300\",\n                \"title\": \"Фейсбилдинг Гимнастика для лица, Керол Мадджио Часть 2\"\n            },\n            {\n                \"start\": \"20251008102500 +0300\",\n                \"stop\": \"20251008102900 +0300\",\n 